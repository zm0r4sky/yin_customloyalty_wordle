{
  "name": "yin-customloyalty-wordle",
  "version": "1.0.0",
  "description": "YIN Wordle PWA with Vitest Unit and Playwright E2E Tests in TypeScript",
  "main": "pwa_mvp/app.js",
  "scripts": {
    "build": "tsc",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test": "npm run build && npm run test:unit && npm run test:e2e",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "serve": "http-server ./pwa_mvp -p 8080",
    "serve:test": "http-server ./pwa_mvp -p 8090"
  },
  "devDependencies": {
    "@playwright/test": "^1.43.0",
    "@types/node": "^20.11.0",
    "happy-dom": "^14.12.0",
    "http-server": "^14.1.1",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
